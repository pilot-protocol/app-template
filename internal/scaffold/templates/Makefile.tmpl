# {{.BinaryName}} — Pilot Protocol app-store adapter for {{.ID}}.
# GENERATED by pilot-app. Build + publish loop:
#   make gen-key        # one-time: create the publisher keypair
#   make package        # build -> sha256-pin -> sign manifest -> tar
#   make publish-help   # print the exact gh + catalogue PR steps

APP_ID        := {{.ID}}
BIN           := {{.BinaryName}}
BUNDLE        := bundle
PILOTCTL      ?= pilotctl
PUBLISHER_KEY ?= {{.Publisher.KeyFile}}
VERSION       := $(shell sed -n 's/.*"app_version": "\([^"]*\)".*/\1/p' manifest.json)
TARBALL       := $(APP_ID)-$(VERSION).tar.gz

.PHONY: build test bundle package gen-key verify clean publish-help

build:
	go build -o $(BIN) ./cmd/{{.BinaryName}}

test:
	go vet ./...
	go test ./...

# One-time: generate an ed25519 publisher keypair (prints the public side).
gen-key:
	$(PILOTCTL) appstore gen-key $(PUBLISHER_KEY)

# Assemble a signed bundle: manifest.json (sha256-pinned + ed25519-signed) +
# bin/<binary>. Signing happens AFTER sha256 pinning — binary.sha256 is part of
# the signed payload. The supervisor re-verifies this signature on every spawn.
bundle: build
	@rm -rf $(BUNDLE)
	@mkdir -p $(BUNDLE)/bin
	@cp $(BIN) $(BUNDLE)/bin/$(BIN)
	@SHA=$$(shasum -a 256 $(BUNDLE)/bin/$(BIN) | awk '{print $$1}'); \
	  echo "binary sha256: $$SHA"; \
	  sed "s/\"sha256\": \"[0-9a-f]*\"/\"sha256\": \"$$SHA\"/" manifest.json > $(BUNDLE)/manifest.json
	@test -f $(PUBLISHER_KEY) || { echo "no publisher key — run 'make gen-key' first"; exit 1; }
	@$(PILOTCTL) appstore sign --key $(PUBLISHER_KEY) "$(BUNDLE)/manifest.json"
	@echo "signed bundle ready at ./$(BUNDLE)"

# Package the signed bundle as the release artifact operators download.
# Its sha256 is what you pin as bundle_sha256 in catalogue.json.
package: bundle
	tar -czf $(TARBALL) -C $(BUNDLE) .
	@echo "release artifact: $(TARBALL)"
	@shasum -a 256 $(TARBALL)

verify: bundle
	$(PILOTCTL) appstore verify $(BUNDLE)

clean:
	rm -rf $(BIN) $(BUNDLE) $(APP_ID)-*.tar.gz

publish-help: package
	@echo ""
	@echo "Publish $(APP_ID) v$(VERSION):"
	@echo "  1. gh release create {{.Namespace}}-v$(VERSION) -R pilot-protocol/catalog \\"
	@echo "       $(TARBALL) -t \"$(APP_ID) v$(VERSION)\" -n \"...\""
	@echo "  2. add this entry to catalogue/catalogue.json on TeoSlayer/pilotprotocol (via PR):"
	@echo "     {\"id\":\"$(APP_ID)\",\"version\":\"$(VERSION)\","
	@echo "      \"description\":\"{{.Description}}\","
	@echo "      \"bundle_url\":\"https://github.com/pilot-protocol/catalog/releases/download/{{.Namespace}}-v$(VERSION)/$(TARBALL)\","
	@echo "      \"bundle_sha256\":\"$$(shasum -a 256 $(TARBALL) | awk '{print $$1}')\"}"
