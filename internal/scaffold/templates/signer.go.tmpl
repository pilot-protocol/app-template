// Managed-key signing for the {{.ID}} adapter. This app is keyless: it holds no
// partner API key. Instead it proves WHO is calling to the Pilot broker, which
// holds the one master key, meters per caller, and forwards to the partner.
//
// The adapter signs each broker request with the per-app ed25519 identity the
// daemon provisions via --identity. The broker verifies the signature, so a
// caller cannot be spoofed and metering cannot be charged to someone else.
//
// The canonical byte string and headers MUST match the broker's verifier
// (internal/broker/identity.go in the app-template repo). GENERATED by
// pilot-app; edit pilot.app.yaml and re-generate.
package backend

import (
	"crypto/ed25519"
	"crypto/rand"
	"crypto/sha256"
	"encoding/base64"
	"encoding/hex"
	"encoding/json"
	"errors"
	"fmt"
	"os"
	"strconv"
	"strings"
	"time"
)

// Identity header names — the broker reads exactly these.
const (
	hdrCaller    = "X-Pilot-Caller"    // base64(ed25519 public key)
	hdrTimestamp = "X-Pilot-Timestamp" // unix seconds
	hdrSignature = "X-Pilot-Signature" // base64(ed25519 signature)
)

// Signer turns (method, path, body) into the identity headers for one request.
type Signer func(method, path string, body []byte) map[string]string

// canonical is the exact byte string signed/verified: method, path, timestamp,
// and a base64(sha256) of the body, newline-separated. Identical to the broker.
func canonical(method, path, ts string, body []byte) []byte {
	sum := sha256.Sum256(body)
	return []byte(method + "\n" + path + "\n" + ts + "\n" + base64.RawStdEncoding.EncodeToString(sum[:]))
}

// NewSigner loads the ed25519 identity from path and returns a Signer. The
// daemon supplies path via --identity. The file holds the private key as base64
// or hex — either a 32-byte seed or a 64-byte expanded key.
func NewSigner(path string) (Signer, error) {
	priv, err := loadIdentity(path)
	if err != nil {
		return nil, err
	}
	pub := base64.RawStdEncoding.EncodeToString(priv.Public().(ed25519.PublicKey))
	return func(method, path string, body []byte) map[string]string {
		ts := strconv.FormatInt(time.Now().Unix(), 10)
		sig := ed25519.Sign(priv, canonical(method, path, ts, body))
		return map[string]string{
			hdrCaller:    pub,
			hdrTimestamp: ts,
			hdrSignature: base64.RawStdEncoding.EncodeToString(sig),
		}
	}, nil
}

// loadIdentity reads the ed25519 private key from path, creating it on first
// start if absent. The daemon points --identity at $APP/identity.json but does
// NOT create the file — per the app-store contract, a key.sign app provisions
// its own per-app key on first run. The identity is JSON:
// {"private_key":"<base64>","public_key":"<base64>"} (std base64 of the 64-byte
// ed25519 key). For flexibility (tests/ops) a bare base64/hex seed (32 bytes)
// or full key (64 bytes) is also accepted.
func loadIdentity(path string) (ed25519.PrivateKey, error) {
	if path == "" {
		return nil, fmt.Errorf("managed adapter: --identity is required (the daemon supplies it)")
	}
	raw, err := os.ReadFile(path)
	if err != nil {
		if errors.Is(err, os.ErrNotExist) {
			return createIdentity(path)
		}
		return nil, fmt.Errorf("managed adapter: read identity %s: %w", path, err)
	}

	// Primary: the daemon's identity.json shape.
	var f struct {
		PrivateKey string `json:"private_key"`
	}
	if json.Unmarshal(raw, &f) == nil && f.PrivateKey != "" {
		key, derr := decodeKey(f.PrivateKey)
		if derr != nil {
			return nil, fmt.Errorf("managed adapter: identity %s: private_key: %w", path, derr)
		}
		return toPrivateKey(key, path)
	}

	// Fallback: a bare base64/hex key (no JSON wrapper).
	key, derr := decodeKey(strings.TrimSpace(string(raw)))
	if derr != nil {
		return nil, fmt.Errorf("managed adapter: identity %s: %w", path, derr)
	}
	return toPrivateKey(key, path)
}

// createIdentity generates a fresh ed25519 keypair, persists it at path in the
// daemon's identity.json shape (0600), and returns the private key. The broker
// accepts any validly-signed caller and meters per identity, so a first-run
// self-provisioned key is a new metered caller — no pre-registration needed.
func createIdentity(path string) (ed25519.PrivateKey, error) {
	pub, priv, err := ed25519.GenerateKey(rand.Reader)
	if err != nil {
		return nil, fmt.Errorf("managed adapter: generate identity: %w", err)
	}
	rec := struct {
		PrivateKey string `json:"private_key"`
		PublicKey  string `json:"public_key"`
	}{
		PrivateKey: base64.StdEncoding.EncodeToString(priv),
		PublicKey:  base64.StdEncoding.EncodeToString(pub),
	}
	b, err := json.MarshalIndent(rec, "", "  ")
	if err != nil {
		return nil, err
	}
	if err := os.WriteFile(path, append(b, '\n'), 0o600); err != nil {
		return nil, fmt.Errorf("managed adapter: persist identity %s: %w", path, err)
	}
	return priv, nil
}

func toPrivateKey(key []byte, path string) (ed25519.PrivateKey, error) {
	switch len(key) {
	case ed25519.SeedSize:
		return ed25519.NewKeyFromSeed(key), nil
	case ed25519.PrivateKeySize:
		return ed25519.PrivateKey(key), nil
	default:
		return nil, fmt.Errorf("managed adapter: identity %s: unexpected key length %d", path, len(key))
	}
}

func decodeKey(s string) ([]byte, error) {
	s = strings.TrimSpace(s)
	if b, err := base64.StdEncoding.DecodeString(s); err == nil {
		return b, nil
	}
	if b, err := base64.RawStdEncoding.DecodeString(s); err == nil {
		return b, nil
	}
	if b, err := hex.DecodeString(s); err == nil {
		return b, nil
	}
	return nil, fmt.Errorf("not valid base64 or hex")
}
