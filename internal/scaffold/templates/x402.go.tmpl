// x402 payment layer for {{.ID}}. GENERATED by pilot-app (backend.x402).
//
// When the backend answers with HTTP 402 and an x402 challenge, this wraps the
// HTTP client: it parses the payment options, picks one within the configured
// networks/asset and per-call cap, asks the Pilot wallet ({{.Backend.X402.Payer}})
// to satisfy it over the daemon IPC broker, and retries the request once with
// the resulting X-PAYMENT header. The agent never sees the 402. The wallet's own
// spend caps are the second line of defence behind the cap below.
package backend

import (
	"bytes"
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"io"
	"math/big"
	"net"
	"net/http"
	"strings"
	"time"

	"github.com/pilot-protocol/app-store/pkg/ipc"
)

const (
	xPaymentHeader  = "X-PAYMENT"
	xPaymentReceipt = "X-PAYMENT-RESPONSE"
)

// x402Accepts is one payment option from a 402 challenge body.
type x402Accepts struct {
	Scheme            string `json:"scheme"`
	Network           string `json:"network"`
	NetworkName       string `json:"networkName"`
	Asset             string `json:"asset"`
	PayTo             string `json:"payTo"`
	MaxAmountRequired string `json:"maxAmountRequired"`
	Description       string `json:"description"`
	Resource          string `json:"resource"`
}

type x402Challenge struct {
	Version int           `json:"x402Version"`
	Accepts []x402Accepts `json:"accepts"`
}

// x402Doer wraps an inner HTTP doer with one capped pay-and-retry on 402.
type x402Doer struct {
	inner      httpDoer
	daemonAddr string
	payMethod  string
	networks   []string
	asset      string
	maxAtomic  *big.Int // nil = rely on the wallet's own caps
}

func newX402Doer(inner httpDoer, daemonAddr string) httpDoer {
	d := &x402Doer{
		inner:      inner,
		daemonAddr: daemonAddr,
		payMethod:  {{printf "%q" .Backend.X402.Method}},
		networks:   {{printf "%#v" .Backend.X402.Networks}},
		asset:      {{printf "%q" .Backend.X402.Asset}},
	}
	{{- if .Backend.X402.MaxAtomic}}
	d.maxAtomic, _ = new(big.Int).SetString({{printf "%q" .Backend.X402.MaxAtomic}}, 10)
	{{- end}}
	return d
}

func (d *x402Doer) networkOK(a x402Accepts) bool {
	if len(d.networks) == 0 {
		return true
	}
	for _, n := range d.networks {
		if strings.EqualFold(n, a.Network) || strings.EqualFold(n, a.NetworkName) {
			return true
		}
	}
	return false
}

// selectOption applies the network/asset allow-list and the per-call cap.
func (d *x402Doer) selectOption(ch *x402Challenge) (*x402Accepts, error) {
	if ch == nil || len(ch.Accepts) == 0 {
		return nil, errors.New("x402: 402 carried no usable payment challenge")
	}
	var eligible bool
	var offered []string
	for i := range ch.Accepts {
		a := ch.Accepts[i]
		name := a.NetworkName
		if name == "" {
			name = a.Network
		}
		offered = append(offered, name)
		if !d.networkOK(a) {
			continue
		}
		if d.asset != "" && a.Asset != "" && !strings.EqualFold(d.asset, a.Asset) {
			continue
		}
		eligible = true
		if d.maxAtomic != nil {
			amt, ok := new(big.Int).SetString(strings.TrimSpace(a.MaxAmountRequired), 10)
			if !ok || amt.Cmp(d.maxAtomic) > 0 {
				continue
			}
		}
		return &a, nil
	}
	if eligible {
		return nil, fmt.Errorf("x402: charge exceeds the per-call cap (%v atomic units)", d.maxAtomic)
	}
	return nil, fmt.Errorf("x402: no option matches networks %v / asset %q (offered: %s)", d.networks, d.asset, strings.Join(offered, ", "))
}

// Do sends req; on a 402 it pays once (capped) and retries with X-PAYMENT.
func (d *x402Doer) Do(req *http.Request) (*http.Response, error) {
	var body []byte
	if req.Body != nil {
		b, err := io.ReadAll(req.Body)
		_ = req.Body.Close()
		if err != nil {
			return nil, fmt.Errorf("x402: buffering body: %w", err)
		}
		body = b
		req.Body = io.NopCloser(bytes.NewReader(body))
	}
	resp, err := d.inner.Do(req)
	if err != nil || resp.StatusCode != http.StatusPaymentRequired {
		return resp, err
	}
	chBody, _ := io.ReadAll(resp.Body)
	_ = resp.Body.Close()
	var ch x402Challenge
	if json.Unmarshal(chBody, &ch) != nil {
		return nil, errors.New("x402: 402 body is not a valid challenge")
	}
	opt, serr := d.selectOption(&ch)
	if serr != nil {
		return nil, serr
	}
	xpay, perr := d.satisfy(req.Context(), *opt)
	if perr != nil {
		return nil, fmt.Errorf("x402: wallet could not satisfy charge: %w", perr)
	}
	retry := req.Clone(req.Context())
	if body != nil {
		retry.Body = io.NopCloser(bytes.NewReader(body))
		retry.ContentLength = int64(len(body))
	}
	retry.Header.Set(xPaymentHeader, xpay)
	return d.inner.Do(retry)
}

// satisfy asks the wallet, over the daemon IPC broker, to sign the payment for
// this option and return the X-PAYMENT header value. The ipc.call grant
// ({{.Backend.X402.Grant}}) gates this; the broker stamps our app identity.
func (d *x402Doer) satisfy(ctx context.Context, a x402Accepts) (string, error) {
	if d.daemonAddr == "" {
		return "", errors.New("no daemon address (--addr) to reach the wallet")
	}
	network := "unix"
	if !strings.Contains(d.daemonAddr, "/") {
		network = "tcp"
	}
	conn, err := (&net.Dialer{Timeout: 5 * time.Second}).DialContext(ctx, network, d.daemonAddr)
	if err != nil {
		return "", fmt.Errorf("dial daemon: %w", err)
	}
	defer conn.Close()
	var out struct {
		XPayment string `json:"x_payment"`
	}
	if err := ipc.Call(conn, d.payMethod, a, &out); err != nil {
		return "", err
	}
	if out.XPayment == "" {
		return "", errors.New("wallet returned an empty payment authorization")
	}
	return out.XPayment, nil
}
