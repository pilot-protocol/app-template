// Command {{.BinaryName}} is the Pilot Protocol app-store front door for {{.ID}}.
//
// GENERATED by pilot-app from pilot.app.yaml. Re-generating overwrites this
// file; keep app-specific logic in the backend, not here. This adapter is a
// thin, stateless bridge: the pilot daemon spawns it with `--socket`, it serves
// the app-store IPC protocol on that unix socket, and forwards each registered
// method to the {{.Backend.Type}} backend. It owns no state.
//
// Config resolution (highest precedence first):
//   1. env: {{.Backend.EnvPrefix}}_BACKEND_URL (dev override)
//   2. file: $APP/config.json  ({"backend_url":"..."})  (optional override)
//   3. default baked-in backend (works with no config)
package main

import (
	"context"
	"encoding/json"
	"flag"
	"fmt"
	"log"
	"net"
	"os"
	"os/signal"
	"path/filepath"
{{- if .Backend.Headers}}
	"strings"
{{- end}}
	"syscall"
	"time"

	"github.com/pilot-protocol/app-store/pkg/ipc"
	"{{.GoModule}}/internal/backend"
)

func main() {
	// The pilot daemon spawns every app with the full standard lifecycle flag
	// set. We MUST define all of them or Go's flag package hard-fails ("flag
	// provided but not defined") and the supervisor sees a crash-loop. This
	// stateless adapter only needs --socket and --manifest; the rest are
	// accepted and ignored.
	socket := flag.String("socket", "", "unix socket path to listen on (provided by the pilot daemon)")
	manifestPath := flag.String("manifest", "", "path to the pinned manifest.json (its dir is the app root)")
{{- if .Backend.X402}}
	addr := flag.String("addr", "", "daemon broker address (used by the x402 payment layer to reach the wallet)")
{{- else}}
	_ = flag.String("addr", "", "daemon address (unused by this app)")
{{- end}}
	_ = flag.String("db", "", "per-app sqlite path (unused: this app is stateless)")
{{- if .Managed}}
	identity := flag.String("identity", "", "per-app ed25519 identity path (used to sign managed-broker requests)")
{{- else}}
	_ = flag.String("identity", "", "per-app identity path (unused by this app)")
{{- end}}
	_ = flag.String("cap-state", "", "spend-cap state path (unused by this app)")
	flag.Parse()
	if *socket == "" {
		log.Fatal("{{.BinaryName}}: --socket is required (the pilot daemon supplies it)")
	}

{{- if eq .Backend.Type "http"}}
	cfg := resolveConfig(*manifestPath)
{{- if .Managed}}
	signer, err := backend.NewSigner(*identity)
	if err != nil {
		log.Fatalf("{{.BinaryName}}: %v", err)
	}
{{- end}}
	client, err := backend.New(backend.Config{BaseURL: cfg.BackendURL{{if .Backend.Headers}}, Headers: resolveHeaders(*manifestPath){{end}}{{if .Backend.X402}}, DaemonAddr: *addr{{end}}{{if .Managed}}, Sign: signer{{end}}})
	if err != nil {
		log.Fatalf("{{.BinaryName}}: backend config: %v", err)
	}
{{- else}}
	runner := backend.NewRunner({{printf "%#v" .Backend.Command}}{{range .Backend.EnvPassthrough}}, {{printf "%q" .}}{{end}})
{{- end}}

	d := ipc.NewDispatcher()
{{- if eq .Backend.Type "http"}}
	registerHandlers(d, client, readAppVersion(*manifestPath), cfg.BackendURL)
{{- else}}
	registerHandlers(d, runner, readAppVersion(*manifestPath))
{{- end}}

	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	if err := serve(ctx, *socket, d); err != nil {
		log.Fatalf("{{.BinaryName}}: serve: %v", err)
	}
}

// serve listens on the unix socket and runs ipc.Serve per connection. The
// daemon dials the socket per call, so connections are short-lived; one Serve
// goroutine per accepted conn keeps concurrent callers independent.
func serve(ctx context.Context, socketPath string, d *ipc.Dispatcher) error {
	_ = os.Remove(socketPath) // a stale socket from a crashed prior instance would block Listen
	ln, err := net.Listen("unix", socketPath)
	if err != nil {
		return fmt.Errorf("listen %s: %w", socketPath, err)
	}
	defer ln.Close()
	defer os.Remove(socketPath)

	go func() {
		<-ctx.Done()
		_ = ln.Close() // unblocks Accept
	}()

	log.Printf("{{.BinaryName}}: listening on %s", socketPath)
	for {
		conn, err := ln.Accept()
		if err != nil {
			if ctx.Err() != nil {
				return nil // clean shutdown
			}
			return fmt.Errorf("accept: %w", err)
		}
		go func() {
			defer conn.Close()
			if err := ipc.Serve(ctx, conn, d); err != nil {
				log.Printf("{{.BinaryName}}: conn closed with error: %v", err)
			}
		}()
	}
}

// registerHandlers wires each IPC method to its backend call. Method names MUST
// match the manifest's `exposes` list, or the daemon won't broker them.
{{- if eq .Backend.Type "http"}}
func registerHandlers(d *ipc.Dispatcher, c *backend.Client, version, backendURL string) {
{{- range .Methods}}
	d.Register("{{.Name}}", forward{{if eq .HTTP.Verb "POST"}}Post{{else}}Get{{end}}(c, "{{.HTTP.Path}}", dur("{{.TimeoutFor}}"))) // {{.Duration}}
{{- end}}
	d.Register("{{.Namespace}}.help", helpHandler(version, backendURL))
}

// forwardGet copies the flat JSON payload into the query string of a GET.
func forwardGet(c *backend.Client, path string, timeout time.Duration) ipc.Handler {
	return func(ctx context.Context, req *ipc.Envelope) (json.RawMessage, error) {
		params, err := stringParams(req.Payload)
		if err != nil {
			return nil, err
		}
		ctx, cancel := context.WithTimeout(ctx, timeout)
		defer cancel()
		return c.Get(ctx, path, params)
	}
}

// forwardPost forwards the JSON payload verbatim as the POST body.
func forwardPost(c *backend.Client, path string, timeout time.Duration) ipc.Handler {
	return func(ctx context.Context, req *ipc.Envelope) (json.RawMessage, error) {
		ctx, cancel := context.WithTimeout(ctx, timeout)
		defer cancel()
		return c.PostRaw(ctx, path, req.Payload)
	}
}
{{- else}}
func registerHandlers(d *ipc.Dispatcher, r *backend.Runner, version string) {
{{- range .Methods}}
	d.Register("{{.Name}}", forwardExec(r, backend.Spec{ {{if .CLI.Passthrough}}Passthrough: true{{else}}Args: {{printf "%#v" .CLI.Args}}, ParamsAsFlags: {{.CLI.ParamsAsFlags}}{{end}} }, dur("{{.TimeoutFor}}"))) // {{.Duration}}
{{- end}}
	d.Register("{{.Namespace}}.help", helpHandler(version))
}

// forwardExec runs the backend CLI for one method and returns its output as the
// IPC reply. Enumerated methods fill ${field} placeholders from the payload;
// passthrough methods take a verbatim "args" array. Both accept an optional
// "stdin" string piped to the child.
func forwardExec(r *backend.Runner, spec backend.Spec, timeout time.Duration) ipc.Handler {
	return func(ctx context.Context, req *ipc.Envelope) (json.RawMessage, error) {
		call, err := decodeCall(spec, req.Payload)
		if err != nil {
			return nil, err
		}
		ctx, cancel := context.WithTimeout(ctx, timeout)
		defer cancel()
		return r.Run(ctx, spec, call)
	}
}

// decodeCall extracts one invocation's dynamic inputs from the IPC payload. A
// passthrough method reads {"args":[...], "stdin"?:"..."} — the args array is
// the verbatim argv appended to the base command. An enumerated method reads a
// flat object of string params; the reserved key "stdin" is piped to the child.
func decodeCall(spec backend.Spec, raw json.RawMessage) (backend.Call, error) {
	var call backend.Call
	if spec.Passthrough {
		var p struct {
			Args  []string `json:"args"`
			Stdin string   `json:"stdin"`
		}
		if len(raw) > 0 {
			if err := json.Unmarshal(raw, &p); err != nil {
				return call, fmt.Errorf(`passthrough payload must be {"args":[...],"stdin"?:"..."}: %w`, err)
			}
		}
		call.Args, call.Stdin = p.Args, p.Stdin
		return call, nil
	}
	params, err := stringParams(raw)
	if err != nil {
		return call, err
	}
	if s, ok := params["stdin"]; ok {
		call.Stdin = s
		delete(params, "stdin")
	}
	call.Params = params
	return call, nil
}
{{- end}}

// dur parses a Go duration literal baked in at generation time; the values come
// from validated config, so a parse error is a generator bug, not user input.
func dur(s string) time.Duration {
	d, err := time.ParseDuration(s)
	if err != nil {
		panic("{{.BinaryName}}: bad generated duration " + s + ": " + err.Error())
	}
	return d
}

// ── discovery: {{.Namespace}}.help ──────────────────────────────────────────
//
// `pilotctl appstore list/status` only surface the manifest's flat `exposes`
// names. {{.Namespace}}.help fills that gap: a single local call (no backend
// round-trip) returning every method with params, kind, and an expected-latency
// class so an agent can pick the cheapest method before spending a slow one.

type methodDoc struct {
	Method    string            `json:"method"`
	Kind      string            `json:"kind"`
	Summary   string            `json:"summary"`
	Params    map[string]string `json:"params,omitempty"`
	Duration  string            `json:"duration"`
	Roundtrip string            `json:"typical_roundtrip,omitempty"`
}

var helpMethods = []methodDoc{
{{- range $m := .Methods}}
	{Method: "{{$m.Name}}", Kind: "{{$m.Kind}}", Duration: "{{$m.Duration}}",
		Summary: {{printf "%q" $m.Summary}},
{{- if $m.Params}}
		Params: map[string]string{
{{- range $k := $m.SortedParamKeys}}
			{{printf "%q" $k}}: {{printf "%q" (index $m.Params $k)}},
{{- end}}
		},
{{- end}}
{{- if $m.Roundtrip}}
		Roundtrip: {{printf "%q" $m.Roundtrip}},
{{- end}}
	},
{{- end}}
	{Method: "{{.Namespace}}.help", Kind: "meta", Duration: "fast",
		Summary: "This document — every method with params, kind, and duration class.",
		Roundtrip: "instant (local, no backend call)"},
}

type helpDoc struct {
	App             string            `json:"app"`
	Version         string            `json:"version"`
	Description     string            `json:"description"`
{{- if eq .Backend.Type "http"}}
	Backend         string            `json:"backend"`
{{- end}}
	DurationClasses map[string]string `json:"duration_classes"`
	Methods         []methodDoc       `json:"methods"`
}

{{if eq .Backend.Type "http"}}func helpHandler(version, backendURL string) ipc.Handler {{"{"}}{{else}}func helpHandler(version string) ipc.Handler {{"{"}}{{end}}
	doc := helpDoc{
		App:         "{{.ID}}",
		Version:     version,
		Description: {{printf "%q" .Description}},
{{- if eq .Backend.Type "http"}}
		Backend:     backendURL,
{{- end}}
		DurationClasses: map[string]string{
			"fast": "<~1s — status or cheap call",
			"med":  "~1-5s — moderate work",
			"slow": "~5-30s — heavy / multi-step",
		},
		Methods: helpMethods,
	}
	raw, _ := json.Marshal(doc)
	return func(ctx context.Context, _ *ipc.Envelope) (json.RawMessage, error) {
		return append(json.RawMessage(nil), raw...), nil
	}
}

// readAppVersion best-effort reads app_version from the pinned manifest so
// {{.Namespace}}.help reports the running version without a drifting constant.
func readAppVersion(manifestPath string) string {
	if manifestPath == "" {
		return "unknown"
	}
	b, err := os.ReadFile(manifestPath)
	if err != nil {
		return "unknown"
	}
	var m struct {
		AppVersion string `json:"app_version"`
	}
	if json.Unmarshal(b, &m) == nil && m.AppVersion != "" {
		return m.AppVersion
	}
	return "unknown"
}

// stringParams decodes a flat JSON object into a string map. Numbers/bools are
// coerced to their literal JSON text so callers can pass {"k":10} or {"x":true}.
func stringParams(raw json.RawMessage) (map[string]string, error) {
	out := map[string]string{}
	if len(raw) == 0 {
		return out, nil
	}
	var m map[string]json.RawMessage
	if err := json.Unmarshal(raw, &m); err != nil {
		return nil, fmt.Errorf("payload must be a JSON object: %w", err)
	}
	for k, v := range m {
		s := string(v)
		var str string
		if json.Unmarshal(v, &str) == nil {
			s = str
		}
		out[k] = s
	}
	return out, nil
}

type appConfig struct {
	BackendURL string `json:"backend_url"`
}

// defaultBackendURL ships the app pointing at production, so a freshly-installed
// app works with NO config — config.json only overrides it (e.g. self-hosted).
// For a managed app this is the Pilot broker (which holds the master key and
// forwards to the partner), never the partner API directly.
const defaultBackendURL = "{{.AdapterBackendURL}}"

func resolveConfig(manifestPath string) appConfig {
	cfg := appConfig{BackendURL: defaultBackendURL}

	appDir := os.Getenv("APP")
	if manifestPath != "" {
		appDir = filepath.Dir(manifestPath)
	}
	if appDir != "" {
		if b, err := os.ReadFile(filepath.Join(appDir, "config.json")); err == nil {
			var fileCfg appConfig
			if json.Unmarshal(b, &fileCfg) == nil && fileCfg.BackendURL != "" {
				cfg.BackendURL = fileCfg.BackendURL
			}
		}
	}
	if v := os.Getenv("{{.Backend.EnvPrefix}}_BACKEND_URL"); v != "" {
		cfg.BackendURL = v
	}
	return cfg
}
{{if .Backend.Headers}}
// resolveHeaders builds the headers sent on every backend request. ${TOKEN}
// placeholders are filled at runtime from the environment or from a flat
// $APP/secrets.json map — so secrets (e.g. an API key) are supplied by the
// operator at install time and are NEVER baked into the bundle.
func resolveHeaders(manifestPath string) map[string]string {
	raw := map[string]string{
{{- range $k := .Backend.SortedHeaderKeys}}
		{{printf "%q" $k}}: {{printf "%q" (index $.Backend.Headers $k)}},
{{- end}}
	}
	secrets := loadSecrets(manifestPath)
	out := make(map[string]string, len(raw))
	for k, v := range raw {
		out[k] = expandSecrets(v, secrets)
	}
	return out
}

// loadSecrets reads $APP/secrets.json (a flat {"NAME":"value"} map) if present.
// Absent or unreadable → empty map (env vars can still satisfy placeholders).
func loadSecrets(manifestPath string) map[string]string {
	dir := os.Getenv("APP")
	if manifestPath != "" {
		dir = filepath.Dir(manifestPath)
	}
	out := map[string]string{}
	if dir == "" {
		return out
	}
	if b, err := os.ReadFile(filepath.Join(dir, "secrets.json")); err == nil {
		_ = json.Unmarshal(b, &out)
	}
	return out
}

// expandSecrets replaces ${NAME} tokens in s, preferring the environment, then
// the secrets map. An unresolved token expands to empty.
func expandSecrets(s string, secrets map[string]string) string {
	out := s
	for {
		i := strings.Index(out, "${")
		if i < 0 {
			break
		}
		j := strings.Index(out[i:], "}")
		if j < 0 {
			break
		}
		name := out[i+2 : i+j]
		val := os.Getenv(name)
		if val == "" {
			val = secrets[name]
		}
		out = out[:i] + val + out[i+j+1:]
	}
	return out
}
{{end}}
