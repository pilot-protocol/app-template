// Package backend is the thin HTTP client the {{.ID}} adapter uses to reach its
// central backend. The adapter holds no state — it forwards each IPC method to
// the backend's matching HTTP endpoint and passes the JSON response straight
// back. GENERATED by pilot-app; edit pilot.app.yaml and re-generate.
package backend

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net"
	"net/http"
	"net/url"
	"strings"
	"time"
)

// httpDoer is the minimal client surface (satisfied by *http.Client and, when
// x402 is enabled, by the pay-and-retry wrapper).
type httpDoer interface {
	Do(*http.Request) (*http.Response, error)
}

// Client talks to one backend over HTTP.
type Client struct {
	baseURL string
	headers map[string]string
	http    httpDoer
{{- if .Managed}}
	sign    Signer // managed: stamp the verified caller identity on every request
{{- end}}
}

// Config configures a Client. BaseURL is required. Headers (if any) are sent on
// every request — e.g. an API key resolved by the caller before New.
type Config struct {
	BaseURL string
	Headers map[string]string
	Timeout time.Duration
	// DaemonAddr is the pilot daemon broker address (--addr), used by the x402
	// payment layer to reach the wallet. Empty when x402 is disabled.
	DaemonAddr string
{{- if .Managed}}
	// Sign attaches the caller-identity headers the broker verifies. Required
	// for this managed (keyless) adapter.
	Sign Signer
{{- end}}
}

// New returns a Client. Per-call deadlines come from the request context (the
// handlers set them per method); Timeout here is a generous safety ceiling so a
// wedged connection can't hang a goroutine forever. Zero defaults to 200s.
//
// The transport is tuned for one long-lived backend: keep-alive reuse (no TLS
// handshake per call) plus explicit dial/handshake deadlines so a network blip
// fails fast instead of hanging.
func New(cfg Config) (*Client, error) {
	base := strings.TrimRight(cfg.BaseURL, "/")
	if base == "" {
		return nil, fmt.Errorf("backend: BaseURL is required")
	}
	if _, err := url.Parse(base); err != nil {
		return nil, fmt.Errorf("backend: bad BaseURL %q: %w", base, err)
	}
	to := cfg.Timeout
	if to == 0 {
		to = 300 * time.Second // ceiling; per-method context deadlines (often shorter) govern
	}
	tr := &http.Transport{
		Proxy:                 http.ProxyFromEnvironment,
		DialContext:           (&net.Dialer{Timeout: 5 * time.Second, KeepAlive: 30 * time.Second}).DialContext,
		ForceAttemptHTTP2:     true,
		MaxIdleConns:          32,
		MaxIdleConnsPerHost:   16,
		IdleConnTimeout:       90 * time.Second,
		TLSHandshakeTimeout:   10 * time.Second,
		ExpectContinueTimeout: 1 * time.Second,
	}
	var doer httpDoer = &http.Client{Timeout: to, Transport: tr}
{{- if .Backend.X402}}
	// Paid (x402) backend: wrap the client so a 402 is auto-paid via the wallet.
	doer = newX402Doer(doer, cfg.DaemonAddr)
{{- end}}
{{- if .Managed}}
	if cfg.Sign == nil {
		return nil, fmt.Errorf("backend: managed adapter requires a Signer")
	}
{{- end}}
	return &Client{baseURL: base, headers: cfg.Headers, http: doer{{if .Managed}}, sign: cfg.Sign{{end}}}, nil
}

// Get issues GET <path>?<params> and returns the raw JSON body. Empty-valued
// params are dropped so callers can pass a sparse map. This generic
// pass-through means new backend query knobs work with no adapter change.
func (c *Client) Get(ctx context.Context, path string, params map[string]string) (json.RawMessage, error) {
	q := url.Values{}
	for k, v := range params {
		if v != "" {
			q.Set(k, v)
		}
	}
	u := c.baseURL + path
	if enc := q.Encode(); enc != "" {
		u += "?" + enc
	}
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, u, nil)
	if err != nil {
		return nil, err
	}
{{- if .Managed}}
	c.applySig(req, nil)
{{- end}}
	return c.do(req)
}

// PostRaw issues POST <path> with the caller's payload as the JSON body and
// returns the raw JSON body. An empty payload posts an empty object.
func (c *Client) PostRaw(ctx context.Context, path string, payload json.RawMessage) (json.RawMessage, error) {
	body := []byte(payload)
	if len(bytes.TrimSpace(body)) == 0 {
		body = []byte("{}")
	}
	req, err := http.NewRequestWithContext(ctx, http.MethodPost, c.baseURL+path, bytes.NewReader(body))
	if err != nil {
		return nil, err
	}
	req.Header.Set("Content-Type", "application/json")
{{- if .Managed}}
	c.applySig(req, body)
{{- end}}
	return c.do(req)
}

// Do issues an arbitrary method on <path> with an optional query string, extra
// per-call headers, and JSON body, and returns the raw JSON body. Path
// placeholders are already filled by the caller; query carries the query-located
// params, headers the header-located params, body the body-located + residual
// fields for a body verb. Empty-valued query/header keys are dropped; an empty
// body sends no body (no Content-Type). The path is used verbatim — a raw
// path param (URL-in-path) reaches the backend unescaped.
func (c *Client) Do(ctx context.Context, method, path string, query, headers map[string]string, body json.RawMessage) (json.RawMessage, error) {
	u := c.baseURL + path
	if len(query) > 0 {
		q := url.Values{}
		for k, v := range query {
			if v != "" {
				q.Set(k, v)
			}
		}
		if enc := q.Encode(); enc != "" {
			u += "?" + enc
		}
	}
	var rdr io.Reader
	var bodyBytes []byte
	if len(bytes.TrimSpace(body)) > 0 {
		bodyBytes = []byte(body)
		rdr = bytes.NewReader(bodyBytes)
	}
	req, err := http.NewRequestWithContext(ctx, method, u, rdr)
	if err != nil {
		return nil, err
	}
	if bodyBytes != nil {
		req.Header.Set("Content-Type", "application/json")
	}
	for k, v := range headers {
		if v != "" {
			req.Header.Set(k, v)
		}
	}
{{- if .Managed}}
	c.applySig(req, bodyBytes)
{{- end}}
	return c.do(req)
}
{{- if .Managed}}

// applySig stamps the caller-identity headers the broker verifies. The signed
// path is req.URL.Path, which already includes the /<app-id> prefix from the
// broker base URL — matching exactly what the broker verifies server-side.
func (c *Client) applySig(req *http.Request, body []byte) {
	for k, v := range c.sign(req.Method, req.URL.Path, body) {
		req.Header.Set(k, v)
	}
}
{{- end}}

func (c *Client) do(req *http.Request) (json.RawMessage, error) {
	req.Header.Set("Accept", "application/json")
	for k, v := range c.headers {
		if v != "" {
			req.Header.Set(k, v)
		}
	}
	resp, err := c.http.Do(req)
	if err != nil {
		return nil, fmt.Errorf("backend: %s %s: %w", req.Method, req.URL.Path, err)
	}
	defer resp.Body.Close()
	body, err := io.ReadAll(io.LimitReader(resp.Body, 32<<20)) // 32MiB cap
	if err != nil {
		return nil, fmt.Errorf("backend: read body: %w", err)
	}
	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
		return nil, fmt.Errorf("backend: %s %s -> %d: %s",
			req.Method, req.URL.Path, resp.StatusCode, strings.TrimSpace(string(body)))
	}
	if len(bytes.TrimSpace(body)) == 0 {
		return json.RawMessage(`{}`), nil
	}
	if json.Valid(body) {
		return json.RawMessage(body), nil
	}
	// A 2xx body that isn't JSON (e.g. text/markdown, HTML, plain text) would be
	// an invalid IPC reply. Wrap it into a valid JSON envelope so the agent gets
	// the content plus the backend's declared Content-Type intact.
	wrapped, err := json.Marshal(struct {
		ContentType string `json:"content_type"`
		Content     string `json:"content"`
	}{ContentType: resp.Header.Get("Content-Type"), Content: string(body)})
	if err != nil {
		return nil, fmt.Errorf("backend: wrap non-JSON body: %w", err)
	}
	return json.RawMessage(wrapped), nil
}
