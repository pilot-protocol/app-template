// Package backend is the thin HTTP client the {{.ID}} adapter uses to reach its
// central backend. The adapter holds no state — it forwards each IPC method to
// the backend's matching HTTP endpoint and passes the JSON response straight
// back. GENERATED by pilot-app; edit pilot.app.yaml and re-generate.
package backend

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net"
	"net/http"
	"net/url"
	"strings"
	"time"
)

// Client talks to one backend over HTTP.
type Client struct {
	baseURL string
	headers map[string]string
	http    *http.Client
}

// Config configures a Client. BaseURL is required. Headers (if any) are sent on
// every request — e.g. an API key resolved by the caller before New.
type Config struct {
	BaseURL string
	Headers map[string]string
	Timeout time.Duration
}

// New returns a Client. Per-call deadlines come from the request context (the
// handlers set them per method); Timeout here is a generous safety ceiling so a
// wedged connection can't hang a goroutine forever. Zero defaults to 200s.
//
// The transport is tuned for one long-lived backend: keep-alive reuse (no TLS
// handshake per call) plus explicit dial/handshake deadlines so a network blip
// fails fast instead of hanging.
func New(cfg Config) (*Client, error) {
	base := strings.TrimRight(cfg.BaseURL, "/")
	if base == "" {
		return nil, fmt.Errorf("backend: BaseURL is required")
	}
	if _, err := url.Parse(base); err != nil {
		return nil, fmt.Errorf("backend: bad BaseURL %q: %w", base, err)
	}
	to := cfg.Timeout
	if to == 0 {
		to = 200 * time.Second
	}
	tr := &http.Transport{
		Proxy:                 http.ProxyFromEnvironment,
		DialContext:           (&net.Dialer{Timeout: 5 * time.Second, KeepAlive: 30 * time.Second}).DialContext,
		ForceAttemptHTTP2:     true,
		MaxIdleConns:          32,
		MaxIdleConnsPerHost:   16,
		IdleConnTimeout:       90 * time.Second,
		TLSHandshakeTimeout:   10 * time.Second,
		ExpectContinueTimeout: 1 * time.Second,
	}
	return &Client{baseURL: base, headers: cfg.Headers, http: &http.Client{Timeout: to, Transport: tr}}, nil
}

// Get issues GET <path>?<params> and returns the raw JSON body. Empty-valued
// params are dropped so callers can pass a sparse map. This generic
// pass-through means new backend query knobs work with no adapter change.
func (c *Client) Get(ctx context.Context, path string, params map[string]string) (json.RawMessage, error) {
	q := url.Values{}
	for k, v := range params {
		if v != "" {
			q.Set(k, v)
		}
	}
	u := c.baseURL + path
	if enc := q.Encode(); enc != "" {
		u += "?" + enc
	}
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, u, nil)
	if err != nil {
		return nil, err
	}
	return c.do(req)
}

// PostRaw issues POST <path> with the caller's payload as the JSON body and
// returns the raw JSON body. An empty payload posts an empty object.
func (c *Client) PostRaw(ctx context.Context, path string, payload json.RawMessage) (json.RawMessage, error) {
	body := []byte(payload)
	if len(bytes.TrimSpace(body)) == 0 {
		body = []byte("{}")
	}
	req, err := http.NewRequestWithContext(ctx, http.MethodPost, c.baseURL+path, bytes.NewReader(body))
	if err != nil {
		return nil, err
	}
	req.Header.Set("Content-Type", "application/json")
	return c.do(req)
}

func (c *Client) do(req *http.Request) (json.RawMessage, error) {
	req.Header.Set("Accept", "application/json")
	for k, v := range c.headers {
		if v != "" {
			req.Header.Set(k, v)
		}
	}
	resp, err := c.http.Do(req)
	if err != nil {
		return nil, fmt.Errorf("backend: %s %s: %w", req.Method, req.URL.Path, err)
	}
	defer resp.Body.Close()
	body, err := io.ReadAll(io.LimitReader(resp.Body, 32<<20)) // 32MiB cap
	if err != nil {
		return nil, fmt.Errorf("backend: read body: %w", err)
	}
	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
		return nil, fmt.Errorf("backend: %s %s -> %d: %s",
			req.Method, req.URL.Path, resp.StatusCode, strings.TrimSpace(string(body)))
	}
	if len(bytes.TrimSpace(body)) == 0 {
		return json.RawMessage(`{}`), nil
	}
	return json.RawMessage(body), nil
}
